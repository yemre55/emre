# Bu dosyayı ".env" olarak kopyalayın ve gerçek değerleri girin.
# .env dosyasını ASLA git'e commit etmeyin / paylaşmayın.

# --- MySQL (docker-compose için) ---
# DB_ROOT_PASSWORD sadece MySQL konteynerinin ilk kurulumunda kullanılır.
DB_ROOT_PASSWORD=degistir_bu_guclu_bir_sifre_olsun
DB_NAME=erp_db
DB_USER=erp_user
DB_PASSWORD=degistir_bu_da_guclu_bir_sifre_olsun
# DB_HOST: docker-compose ile çalışırken "mysql" olarak sabitlenir
# (docker-compose.yml'e bakın). Docker'sız/lokal çalıştırırken
# DB_HOST=localhost kullanın.
DB_HOST=localhost
# DB_PORT: docker-compose.yml içinde "3307:3306" olarak eşlenir, yani
# ana makineden (host) bağlanırken 3307 kullanılır. Docker'sız/lokal
# bir MySQL sunucusuna bağlanıyorsanız kendi portunuzu (genelde 3306) girin.
DB_PORT=3307

# MySQL bağlantı havuzu boyutu. Yük altında gereksiz bağlantı tüketimini
# önlemek için varsayılan 8'dir (önceden 32'ydi).
DB_POOL_SIZE=8

# --- SMTP / E-posta Bildirimi (Brevo) ---
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=brevo_kullanici_adiniz
SMTP_PASS=brevo_smtp_anahtariniz
EPOSTA_GONDEREN=dogrulanmis-adresiniz@ornek.com
EPOSTA_ALICI=satinalma@kurum.com
